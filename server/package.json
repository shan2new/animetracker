{
  "name": "anitrack-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AniTrack backend — franchise grouping, AniList cache, scheduled sync, Clerk auth.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "seed": "tsx src/scripts/seed-trending.ts",
    "group": "tsx src/scripts/group-one.ts",
    "news": "tsx src/scripts/news-once.ts",
    "tv": "tsx src/scripts/tv-one.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.205",
    "@clerk/backend": "^1.21.0",
    "@fastify/cors": "^10.0.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
