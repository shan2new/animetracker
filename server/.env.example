# --- Server ---
PORT=8787
# Comma-separated allowed CORS origins (use * for dev only)
CORS_ORIGIN=*

# --- Database (local Postgres on the Mac mini) ---
DATABASE_URL=postgres://localhost:5432/anitrack

# --- Clerk (provided separately) ---
# Networkless JWT verification key (PEM). If set, tokens are verified offline.
CLERK_JWT_KEY=
# Secret key for the Clerk backend SDK (fallback to JWKS verification).
CLERK_SECRET_KEY=
# Accept "Authorization: Bearer dev:<clerkId>" for local testing (1 to enable).
DEV_AUTH_BYPASS=1

# --- OpenRouter (key fetched from Daytona) ---
OPENROUTER_API_KEY=
# Flash-tier model for the interactive search grouping path (temperature-0 classification).
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
# Model for the daily bulk/eager grouping cron.
OPENROUTER_MODEL_BULK=google/gemini-3.1-flash-lite
# Pricier model reserved for genuinely ambiguous side-story splits (see groupingTier()).
OPENROUTER_MODEL_ESCALATE=anthropic/claude-haiku-4.5
# Set to 1 to skip real LLM calls and use the deterministic relation-graph grouping only.
GROUPING_LLM_DISABLED=0

# --- Cerebras (fast, cheap inference) ---
# When set, gpt-oss-120b is the default for franchise grouping (preferred over OpenRouter above)
# AND for spell-correcting a search that returned no AniList hits.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
# Set to 1 to disable LLM spell-correction of zero-result searches.
SEARCH_CORRECT_DISABLED=0

# --- Sync ---
# Max trending franchises to seed on the daily job.
TRENDING_SEED_COUNT=300

# --- TMDB (general-TV source) ---
# v4 read access token (Bearer). Leave empty to disable TV search/sync (anime-only mode).
TMDB_ACCESS_TOKEN=
